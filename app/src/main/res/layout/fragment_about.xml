<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="حول التطبيق"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="دفتر الحسابات PRO MAX هو نظام ذكي لإدارة الديون بينك وبين العملاء، مع تقارير ورسوم بيانية ونسخ احتياطي شامل."
        android:textAlignment="viewStart" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="- إدارة عملاء وديون\n- مشاريع متعددة\n- رسوم بيانية مباشرة\n- استيراد وتصدير"
        android:textAlignment="viewStart" />

    <TextView
        android:id="@+id/buildInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAlignment="viewStart" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="تم التطوير بواسطة عبدالرحمن الظواهري" />

    <TextView
        android:id="@+id/footerYear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2030"
        android:textSize="28sp"
        android:textStyle="bold" />

</LinearLayout>
